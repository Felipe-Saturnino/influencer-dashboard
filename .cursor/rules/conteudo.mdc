## Exclusão em Lista — Nunca `window.confirm()`

Dois cliques + `onBlur` cancel (como `operacoes.mdc` / `lives.mdc`).

```tsx
const [confirmandoId, setConfirmandoId] = useState<string | null>(null);

<button
  type="button"
  onClick={() => {
    if (confirmandoId !== item.id) {
      setConfirmandoId(item.id);
      return;
    }
    void handleExcluir(item);
    setConfirmandoId(null);
  }}
  onBlur={() => setConfirmandoId(null)}
  aria-label={`${confirmandoId === item.id ? "Confirmar exclusão:" : "Excluir:"} ${item.titulo ?? item.texto?.slice(0, 50)}`}
  style={{
    border: `1px solid ${confirmandoId === item.id ? "rgba(232,64,37,0.6)" : hoverStyle}`,
    background: confirmandoId === item.id ? "rgba(232,64,37,0.15)" : hoverBg,
    color: confirmandoId === item.id ? "#ef4444" : defaultColor,
    transition: "all 0.15s",
  }}
>
  <Trash2 size={13} aria-hidden="true" />
  {confirmandoId === item.id && (
    <span style={{ fontSize: 10, marginLeft: 4, fontWeight: 700 }}>Confirmar?</span>
  )}
</button>
```

