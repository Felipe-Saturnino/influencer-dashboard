### Financeiro (`src/pages/operacoes/Financeiro/index.tsx`)

**Datas de ciclo — formato legível, nunca ISO:**
```tsx
function fmtCicloDatas(inicio: string, fim: string): string {
  const fmt = (s: string) => {
    const [, m, d] = s.split("-");
    return `${d}/${m}`;
  };
  return `${fmt(inicio)} – ${fmt(fim)}/${fim.split("-")[0].slice(2)}`;
}
// Aplicar no label do SelectInput de ciclos
label: `${fmtCicloDatas(c.data_inicio, c.data_fim)}${cicloAberto(c) ? " (atual)" : ""}`
