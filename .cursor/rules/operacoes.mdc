    <div>
      <h1 style={{
        fontSize: 22, fontWeight: 800, color: brand.primary,
        fontFamily: FONT_TITLE, margin: 0,
        letterSpacing: "0.5px", textTransform: "uppercase",
      }}>
        Título da Página
      </h1>
      <p style={{ color: t.textMuted, fontFamily: FONT.body, fontSize: 13, margin: "5px 0 0" }}>
        Subtítulo descritivo da página.
      </p>
