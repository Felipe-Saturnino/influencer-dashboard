## Tabelas Operacionais

Tabelas nesta seção são **acionáveis** (contêm botões de ação, expand/collapse). Seguir o padrão abaixo em todos os arquivos.

```tsx
const th: React.CSSProperties = {
  padding: "11px 14px", textAlign: "left",
  fontSize: 10, fontWeight: 700, letterSpacing: "1.2px",
  textTransform: "uppercase", color: t.textMuted,
  background: t.isDark ? "rgba(255,255,255,0.03)" : "rgba(0,0,0,0.02)",
  borderBottom: `1px solid ${t.cardBorder}`,
};
const td: React.CSSProperties = {
  padding: "13px 14px", fontSize: 13,
  color: t.text, fontFamily: FONT.body,
};

// Zebra striping — nunca hardcodar roxo
const zebra = (i: number): React.CSSProperties =>
  i % 2 === 1
    ? { background: t.isDark ? "rgba(255,255,255,0.03)" : "rgba(0,0,0,0.02)" }
    : {};

// Hover nas linhas de dados — obrigatório
<tr
  style={{ borderBottom: `1px solid ${t.cardBorder}` }}
  onMouseEnter={(e) => (e.currentTarget.style.background = t.isDark ? "rgba(255,255,255,0.04)" : "rgba(0,0,0,0.02)")}
  onMouseLeave={(e) => (e.currentTarget.style.background = "transparent")}
>

// Linha clicável (expand/collapse) — tabIndex obrigatório
<tr
  style={{ cursor: "pointer", borderBottom: `1px solid ${t.cardBorder}` }}
  tabIndex={0}
  onClick={() => toggleExpand(id)}
  onKeyDown={(e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); toggleExpand(id); } }}
  onMouseEnter={(e) => (e.currentTarget.style.background = t.isDark ? "rgba(255,255,255,0.04)" : "rgba(0,0,0,0.02)")}
  onMouseLeave={(e) => (e.currentTarget.style.background = "transparent")}
>

// <th> sempre com scope
<th scope="col" style={th}>Nome da coluna</th>

// Wrapper com overflow
<div style={{ overflowX: "auto", borderRadius: 12, border: `1px solid ${t.cardBorder}` }}>
  <table style={{ width: "100%", borderCollapse: "collapse" }}>
```

