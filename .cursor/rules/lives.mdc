// Nunca usar alert() para exibir msg — usar setError() inline
if (!val.ok) {
  setError(val.msg ?? "Dados incompletos para marcar como Fechado.");
  return;
}
```

**Erros de vincularOperadora — inline, nunca alert():**
```tsx
try {
  await vincularOperadoraInfluencerViaApi(userId, slug, scoutId);
} catch (e) {
  setError(e instanceof Error ? e.message : "Erro ao vincular operadora.");
}
